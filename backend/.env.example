# ── FlowForge Docker Compose — Environment Variables ───────────────────────
# Copy this file to backend/.env and fill in your values before running
# docker-compose up.

# ── Shared JWT secret — must be identical across all three services ──────────
JWT_SECRET=replace_with_a_strong_secret_at_least_32_chars

# ── Service-to-service auth key ──────────────────────────────────────────────
# Used by execution-service to call the internal workflow-service endpoint.
# Set both services to the same value and keep it secret.
INTERNAL_SERVICE_KEY=replace_with_a_random_string_32_chars_minimum
