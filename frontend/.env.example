# ── FlowForge Frontend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# In development with `npm run dev`, the Vite proxy handles routing to each
# backend service automatically — VITE_API_BASE_URL can be left empty.

# Base URL for all API calls.
# Leave empty in development (Vite proxy takes over).
# Set to your gateway/reverse-proxy URL in production.
VITE_API_BASE_URL=

# ── Direct service URLs (used in production without Vite proxy) ──────────────
# Only needed if you're NOT routing through a reverse proxy / API gateway.
# VITE_AUTH_SERVICE_URL=http://localhost:8081
# VITE_WORKFLOW_SERVICE_URL=http://localhost:8082
# VITE_EXECUTION_SERVICE_URL=http://localhost:8083
